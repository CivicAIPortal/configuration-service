        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(configuration_service_http_requests_total[5m])) by (route)",
          "legendFormat": "{{route}}",
          "refId": "A"
